PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ai_adaptive_queue
FRONTEND_URL=http://localhost:5173
MONGO_MEMORY_FALLBACK=true
AUTH_DISABLED=true
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=12h
DEFAULT_ADMIN_EMAIL=admin@queue.local
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_USER_EMAIL=user@queue.local
DEFAULT_USER_PASSWORD=user12345
RATE_LIMIT_DISABLED=false
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=1200
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=60
TOKEN_RATE_LIMIT_WINDOW_MS=300000
TOKEN_RATE_LIMIT_MAX=200
LOG_LEVEL=info
LOG_TO_FILE=true
